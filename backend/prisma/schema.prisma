generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String     @id @default(uuid()) @db.Uuid
  name          String
  email         String     @unique
  phone         String?
  password_hash String
  address       String?
  role          String     @default("CUSTOMER")
  createdAt     DateTime   @default(now())

  cartItems     CartItem[]
  orders        Order[]
}

model Category {
  id        String    @id
  name      String
  iconName  String
  isActive  Boolean   @default(true)
  products  Product[]
}

model Product {
  id             String    @id
  categoryId     String
  name           String
  description    String?
  price          Decimal   @db.Decimal(10, 2)
  image          String
  tags           Json?     @default("{}")
  sizes          Json?
  toppings       Json?
  rating         Decimal?  @db.Decimal(3, 2)
  isFavorite     Boolean   @default(false)
  hasPizzaExtras Boolean   @default(false)
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())

  category       Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  cartItems      CartItem[]
  orderItems     OrderItem[]
}

model PizzaExtra {
  id      String @id
  name    String
  options Json
}

model CartItem {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @db.Uuid
  productId       String
  quantity        Int      @default(1)
  price           Decimal? @db.Decimal(10, 2)
  size            String?
  removedToppings Json?
  addedExtras     Json?
  createdAt       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Order {
  id            String      @id @default(uuid()) @db.Uuid
  userId        String      @db.Uuid
  totalAmount   Decimal     @db.Decimal(10, 2)
  status        String      @default("Placed")
  paymentStatus String      @default("Pending")
  createdAt     DateTime    @default(now())

  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderItems    OrderItem[]
  payments      Payment[]
}

model OrderItem {
  id              String  @id @default(uuid()) @db.Uuid
  orderId         String  @db.Uuid
  productId       String
  quantity        Int
  price           Decimal @db.Decimal(10, 2)
  size            String?
  removedToppings Json?
  addedExtras     Json?

  order           Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product         Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Payment {
  id                String   @id @default(uuid()) @db.Uuid
  orderId           String   @db.Uuid
  provider          String   @default("Stripe") // Stripe, Razorpay, etc.
  gatewayOrderId    String?  // Formerly razorpayOrderId
  gatewayPaymentId  String?  // Formerly razorpayPaymentId
  status            String   @default("Pending")
  createdAt         DateTime @default(now())

  order             Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model UIContent {
  id      String @id @default(uuid()) @db.Uuid
  section String
  key     String
  value   String @db.Text
  type    String @default("text") // text, image, json, link

  @@unique([section, key])
}
